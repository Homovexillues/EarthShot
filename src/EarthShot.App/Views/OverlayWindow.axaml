<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="EarthShot.App.Views.OverlayWindow"
        Title="EarthShot Overlay"
        WindowDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        WindowState="FullScreen"
        Background="#66000000"
        TransparencyLevelHint="Transparent">
    <Grid>
        <Image Name="Backdrop" Stretch="Fill"></Image>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Spacing="12">
            <TextBlock Text="EarthShot"
                       Foreground="#FFFFFFFF"
                       FontSize="24"
                       FontWeight="Light"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="按 Esc 退出"
                       Foreground="#CCFFFFFF"
                       FontSize="8"
                       HorizontalAlignment="Center"/>
            <TextBlock Name="CursorLabel"
                       Text="Cursor: -"
                       Foreground="#99FFFFFF"
                       FontSize="8"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>
        <Border Name="Toast"
                IsVisible="False"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#CC000000"
                CornerRadius="8"
                Padding="20,12"
                IsHitTestVisible="False">
            <TextBlock Name="ToastText"
                       Foreground="White"
                       FontSize="18"
                       TextWrapping="Wrap"
                       MaxWidth="600"/>
        </Border>
        <Canvas>
            <!-- 4 个裙边遮罩，围绕 SelectionBox 形成"挖洞"效果 -->
            <Rectangle Name="MaskTop"    Fill="#80000000"/>
            <Rectangle Name="MaskBottom" Fill="#80000000"/>
            <Rectangle Name="MaskLeft"   Fill="#80000000"/>
            <Rectangle Name="MaskRight"  Fill="#80000000"/>
            <Rectangle Name="SelectionBox"
                       IsVisible="False"
                       Stroke="#FD00FFD5"
                       StrokeThickness="0.1"
                       Fill="Transparent">
            </Rectangle>
        </Canvas>
    </Grid>
</Window>
