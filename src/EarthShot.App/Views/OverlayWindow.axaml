<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="EarthShot.App.Views.OverlayWindow"
        Title="EarthShot Overlay"
        WindowDecorations="None"
        Topmost="True"
        ShowInTaskbar="False"
        CanResize="False"
        WindowStartupLocation="Manual"
        WindowState="FullScreen"
        Background="#66000000"
        TransparencyLevelHint="Transparent">
    <Grid>
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    IsHitTestVisible="False"
                    Spacing="12">
            <TextBlock Text="EarthShot"
                       Foreground="#FFFFFFFF"
                       FontSize="24"
                       FontWeight="Light"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="M1 骨架验证 · 按 Esc 退出"
                       Foreground="#CCFFFFFF"
                       FontSize="8"
                       HorizontalAlignment="Center"/>
            <TextBlock Name="CursorLabel"
                       Text="Cursor: -"
                       Foreground="#99FFFFFF"
                       FontSize="8"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>
        <Canvas>
            <Rectangle Name="SelectionBox"
                       IsVisible="False"
                       Stroke="#FD00FFD5"
                       StrokeThickness="2"
                       Fill="#00000000">
            </Rectangle>
        </Canvas>
    </Grid>
</Window>
